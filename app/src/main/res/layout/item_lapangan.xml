<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardLapangan"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="80dp">

            <!-- Colored background -->
            <View
                android:id="@+id/viewHeaderBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1E6B4A"/>

            <!-- Sport initial circle -->
            <TextView
                android:id="@+id/tvSportInitial"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="16dp"
                android:background="@drawable/bg_circle_white_alpha"
                android:gravity="center"
                android:text="FT"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:elevation="2dp"/>

            <!-- Sport label -->
            <TextView
                android:id="@+id/tvSportLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="76dp"
                android:layout_marginBottom="12dp"
                android:text="FUTSAL"
                android:textColor="#80FFFFFF"
                android:textSize="9sp"
                android:letterSpacing="0.15"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"/>

            <!-- Price badge -->
            <TextView
                android:id="@+id/tvHargaBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end|bottom"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Rp 100.000"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_rounded"/>

            <!-- Favorite button -->
            <ImageView
                android:id="@+id/btnFavorite"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:padding="6dp"
                android:src="@drawable/ic_bookmark_outline"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="Simpan"
                android:clickable="true"
                android:focusable="true"/>

        </FrameLayout>

        <!-- Accent bar -->
        <View
            android:id="@+id/viewAccentBar"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:background="#2ECC71"/>

        <!-- Optional image -->
        <ImageView
            android:id="@+id/imgLapangan"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:visibility="gone"/>

        <!-- Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <!-- Name + chip row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvNamaLapangan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Futsal Arena"
                    android:textColor="#0D1117"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/tvJenisOlahraga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="FUTSAL"
                    android:textColor="#FFFFFF"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:background="@drawable/bg_chip_rounded"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F2F4"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Price + Time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Price block -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HARGA / JAM"
                        android:textColor="#9AA3AD"
                        android:textSize="9sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvHarga"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 100.000 / jam"
                        android:textColor="#0D1117"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>

                <!-- Divider vertical -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#F0F2F4"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"/>

                <!-- Time block -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JAM OPERASIONAL"
                        android:textColor="#9AA3AD"
                        android:textSize="9sp"
                        android:letterSpacing="0.08"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvJamTersedia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:00 - 22:00"
                        android:textColor="#0D1117"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="3dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp">

                <View
                    android:id="@+id/viewStatusDot"
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/bg_dot_status"/>

                <TextView
                    android:id="@+id/tvAvailable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tersedia"
                    android:textColor="#2ECC71"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingStart="6dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lihat Detail"
                    android:textColor="#9AA3AD"
                    android:textSize="11sp"
                    android:drawableEnd="@drawable/ic_arrow_right"
                    android:drawablePadding="2dp"
                    android:gravity="center_vertical"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
